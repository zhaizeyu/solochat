# Local host process: use 127.0.0.1 when Postgres is published on the host.
# Container deployment: replace 127.0.0.1 with the actual Postgres service/container hostname.
DATABASE_URL=postgres://postgres:password@127.0.0.1:5432/solochat
# Coolify can also provide split Postgres variables instead of DATABASE_URL:
# PGHOST=your-postgres-service-host
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=password
# PGDATABASE=solochat
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_BUCKET=solochat
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
S3_API_ENDPOINT=https://your-cloudflare-account-id.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=https://uploads.example.com
USE_LOCAL=false
# Optional. Defaults to ./data/uploads.
# LOCAL_UPLOADS_DIR=/app/data/uploads
ADMIN_PASSWORD=change-me
PORT=3101
HOST=0.0.0.0
